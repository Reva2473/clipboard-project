{
  "manifest_version": 3,
  "name": "Cloud Clipboard",
  "version": "1.0",
  "description": "Cloud clipboard manager",
  "permissions": [
    "clipboardRead",
    "storage",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker":"background.js"
  }
}